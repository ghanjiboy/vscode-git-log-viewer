{
  "name": "vscode-git-log-viewer",
  "displayName": "Git Log Viewer",
  "description": "TortoiseGit-style log dialog for files and folders",
  "version": "0.4.8",
  "license": "MIT",
  "publisher": "andiapps",
  "repository": {
    "type": "git",
    "url": "https://github.com/andiapps-dev/vscode-git-log-viewer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitLogViewer.showLog",
        "title": "Show Git Log",
        "icon": "$(git-commit)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gitLogViewer.showLog",
          "group": "zzz_gitLogViewer",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0"
        }
      ],
      "editor/context": [
        {
          "command": "gitLogViewer.showLog",
          "group": "zzz_gitLogViewer",
          "when": "config.git.enabled && gitOpenRepositoryCount != 0 && resourceScheme == file"
        }
      ],
      "commandPalette": [
        {
          "command": "gitLogViewer.showLog",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gitLogViewer.showLog",
        "key": "ctrl+alt+]",
        "mac": "cmd+alt+]",
        "when": "editorTextFocus && config.git.enabled && gitOpenRepositoryCount != 0"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs && cp webview/styles.css dist/webview/styles.css",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "esbuild": "^0.21.0",
    "@vscode/vsce": "^3.9.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0"
  }
}
